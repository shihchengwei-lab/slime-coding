#!/usr/bin/env python3
"""Append Slime Coding evidence to a Git commit message.

Intended for .git/hooks/prepare-commit-msg. It records a short, auditable
summary of the current corridor and staged diff facts. It never blocks commits:
on missing files, non-git directories, or malformed corridor content, it exits
0 without changing the message.
"""
import fnmatch
import os
import re
import subprocess
import sys

PUBSPEC = os.environ.get("SLIME_PUBSPEC", "pubspec.yaml")
META_BASENAMES = {
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    "LICENSE",
    "LICENSE.md",
    "LICENSE.txt",
    "CHANGELOG.md",
}
MARKER = "Slime-Evidence:"


def git(cwd, *args):
    try:
        r = subprocess.run(
            ["git", *args], cwd=cwd, capture_output=True, text=True, timeout=30
        )
        return r.stdout if r.returncode == 0 else ""
    except Exception:
        return ""


def git_root(cwd):
    root = git(cwd, "rev-parse", "--show-toplevel").strip()
    return root or None


def read(path):
    try:
        with open(path, encoding="utf-8") as f:
            return f.read()
    except OSError:
        return ""


def section(text, name):
    m = re.search(rf"^##\s+{re.escape(name)}\s*$", text, re.MULTILINE)
    if not m:
        return ""
    start = m.end()
    nxt = re.search(r"^##\s+", text[start:], re.MULTILINE)
    end = start + nxt.start() if nxt else len(text)
    return text[start:end].strip()


def first_line(block):
    for line in block.splitlines():
        s = line.strip()
        if s:
            return strip_bullet(s)
    return ""


def strip_bullet(line):
    return re.sub(r"^[-*]\s+", "", line.strip()).strip()


def bullet_lines(block):
    out = []
    for line in block.splitlines():
        s = line.strip()
        if s.startswith("- "):
            out.append(strip_bullet(s))
    return out


def semantic_items(block):
    changes = ""
    preserves = ""
    for item in bullet_lines(block):
        lower = item.lower()
        if lower.startswith("this task changes:"):
            changes = item.split(":", 1)[1].strip()
        elif lower.startswith("this task preserves:"):
            preserves = item.split(":", 1)[1].strip()
    return changes, preserves


def corridor(root):
    text = read(os.path.join(root, ".slime", "corridor.md"))
    if not text:
        return None
    m = re.search(r"^#\s*Corridor:\s*(.+?)\s*$", text, re.MULTILINE)
    if not m:
        return None
    changes, preserves = semantic_items(section(text, "Semantic Delta"))
    return {
        "id": m.group(1).strip(),
        "scope": first_line(section(text, "Scope")),
        "changes": changes,
        "preserves": preserves,
        "paths": bullet_lines(section(text, "Paths")),
        "verification": first_line(section(text, "Stop Condition")).strip("`"),
    }


def staged_paths(root):
    return [p for p in git(root, "diff", "--cached", "--name-only").splitlines() if p]


def out_of_corridor(paths, globs):
    if not globs:
        return []
    out = []
    for path in paths:
        if path.startswith(".slime/"):
            continue
        if os.path.basename(path) in META_BASENAMES:
            continue
        if not any(fnmatch.fnmatch(path, glob) for glob in globs):
            out.append(path)
    return out


def parse_deps(text):
    deps = set()
    in_block = False
    for line in text.splitlines():
        if re.match(r"^dependencies:\s*$", line):
            in_block = True
            continue
        if in_block:
            if re.match(r"^\S", line):
                break
            m = re.match(r"^  ([\w-]+):", line)
            if m:
                deps.add(m.group(1))
    return deps


def new_dependencies(root):
    staged = git(root, "show", ":" + PUBSPEC)
    if not staged:
        return []
    head = git(root, "show", "HEAD:" + PUBSPEC)
    if not head:
        return []
    return sorted(parse_deps(staged) - parse_deps(head))


def evidence_block(info, paths, out_corr, deps):
    out_desc = "0" if not out_corr else f"{len(out_corr)} ({', '.join(out_corr[:10])})"
    deps_desc = "none" if not deps else ", ".join(deps)
    lines = [
        MARKER,
        f"Slime-Corridor: {info['id']}",
        f"Slime-Scope: {info['scope'] or 'not recorded'}",
        f"Slime-Delta: {info['changes'] or 'not recorded'}",
        f"Slime-Preserves: {info['preserves'] or 'not recorded'}",
        "Slime-Paths: " + (", ".join(info["paths"]) if info["paths"] else "not recorded"),
        f"Slime-Touched-Files: {len(paths)}",
        f"Slime-Out-Of-Corridor: {out_desc}",
        f"Slime-New-Dependencies: {deps_desc}",
        f"Slime-Verification: {info['verification'] or 'not recorded'}",
    ]
    return "\n".join(lines) + "\n"


def main():
    if len(sys.argv) < 2:
        return 0
    msg_path = sys.argv[1]
    root = git_root(os.getcwd())
    if not root:
        return 0
    msg = read(msg_path)
    if MARKER in msg:
        return 0
    info = corridor(root)
    if not info:
        return 0
    paths = staged_paths(root)
    block = evidence_block(info, paths, out_of_corridor(paths, info["paths"]), new_dependencies(root))
    try:
        with open(msg_path, "a", encoding="utf-8") as f:
            if not msg.endswith("\n"):
                f.write("\n")
            f.write("\n")
            f.write(block)
    except OSError:
        return 0
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
"""Slime Coding controlled-benchmark runner.

Glues the existing building blocks (`experiments/new-run.sh`, `install.sh`,
`experiments/metrics.py`, `experiments/schema/metrics.schema.json`) into a
small CLI so a Phase D matrix (plan §6) can be set up, measured, and
aggregated without ad-hoc shell glue. The agent run itself is still out of
scope: the runner sets the stage and reads the diff, but the agent is driven
by the host Claude Code session.

Subcommands:
    plan       print the (task, condition, run) tuples for a run matrix
    new-cell   materialize a fixture as an isolated run repo + apply condition stack
    measure    invoke metrics.py for one cell, writing metrics.json
    validate   check a metrics.json against schema (required + type + enum + minimum)
    aggregate  walk a runs root and print a markdown summary table

Conditions match docs/VALIDATION_PLAN.md §6:
    A baseline     no install
    B prompt-only  CLAUDE.slime.md + skill + commands (no hooks)
    C hooked-slime install.sh full stack
    D hooked-no-l1 install.sh then drop the prune-inject groups (L1 off)
"""
import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path

CONDITIONS = ["baseline", "prompt-only", "hooked-slime", "hooked-no-l1"]

REPO_ROOT = Path(__file__).resolve().parent.parent  # experiments/slime-bench -> repo root
SCHEMA_PATH = REPO_ROOT / "experiments" / "schema" / "metrics.schema.json"


# ---------------------------------------------------------------------------
# plan
# ---------------------------------------------------------------------------
def cmd_plan(args):
    conds = [c.strip() for c in args.conditions.split(",") if c.strip()]
    for c in conds:
        if c not in CONDITIONS:
            print(f"error: unknown condition {c!r}", file=sys.stderr)
            return 2
    for c in conds:
        for n in range(1, args.runs + 1):
            print(f"{args.task}\t{c}\trun{n}")
    return 0


# ---------------------------------------------------------------------------
# new-cell
# ---------------------------------------------------------------------------
def cmd_new_cell(args):
    cond = args.condition
    if cond not in CONDITIONS:
        print(f"error: unknown condition {cond!r}", file=sys.stderr)
        return 2
    cell = Path(args.root) / args.task / cond / f"run{args.run}"
    if cell.exists():
        print(f"error: cell already exists: {cell}", file=sys.stderr)
        return 1
    cell.parent.mkdir(parents=True, exist_ok=True)

    new_run = REPO_ROOT / "experiments" / "new-run.sh"
    r = subprocess.run(
        ["bash", str(new_run), args.fixture, str(cell)],
        capture_output=True, text=True, encoding="utf-8", errors="replace")
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode

    if cond == "baseline":
        pass
    elif cond == "prompt-only":
        apply_prompt_only(cell)
    elif cond == "hooked-slime":
        apply_hooked(cell)
    elif cond == "hooked-no-l1":
        apply_hooked(cell)
        strip_l1(cell)

    print(str(cell))
    return 0


def apply_prompt_only(cell):
    src_claude = REPO_ROOT / "templates" / "CLAUDE.slime.md"
    if src_claude.exists():
        shutil.copy(src_claude, cell / "CLAUDE.slime.md")
    skills_dir = cell / ".claude" / "skills"
    skills_dir.mkdir(parents=True, exist_ok=True)
    shutil.copytree(REPO_ROOT / "skills" / "slime-navigate",
                    skills_dir / "slime-navigate")
    commands_dir = cell / ".claude" / "commands"
    commands_dir.mkdir(parents=True, exist_ok=True)
    for f in (REPO_ROOT / "commands").glob("*.md"):
        shutil.copy(f, commands_dir / f.name)


def apply_hooked(cell):
    install = REPO_ROOT / "install.sh"
    r = subprocess.run(["bash", str(install), str(cell)],
                       capture_output=True, text=True,
                       encoding="utf-8", errors="replace")
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        raise SystemExit(r.returncode)


def strip_l1(cell):
    settings_path = cell / ".claude" / "settings.json"
    s = json.loads(settings_path.read_text(encoding="utf-8"))
    hooks = s.get("hooks", {})
    for event in ("SessionStart", "UserPromptSubmit"):
        groups = hooks.get(event, [])
        kept = [g for g in groups
                if not any("prune-inject" in h.get("command", "")
                           for h in g.get("hooks", []))]
        if kept:
            hooks[event] = kept
        else:
            hooks.pop(event, None)
    settings_path.write_text(json.dumps(s, indent=2) + "\n", encoding="utf-8")


# ---------------------------------------------------------------------------
# measure
# ---------------------------------------------------------------------------
def cmd_measure(args):
    cell = Path(args.cell).resolve()
    # Infer (task, condition, run) from <root>/<task>/<condition>/run<N>
    parts = cell.parts
    try:
        cond_idx = next(i for i, p in enumerate(parts) if p in CONDITIONS)
    except StopIteration:
        print(f"error: cell path missing <condition> segment: {cell}", file=sys.stderr)
        return 2
    if cond_idx < 1 or not parts[-1].startswith("run"):
        print(f"error: cell path doesn't match <task>/<condition>/run<N>: {cell}",
              file=sys.stderr)
        return 2
    task = parts[cond_idx - 1]
    cond = parts[cond_idx]
    try:
        run_n = int(parts[-1][3:])
    except ValueError:
        print(f"error: run segment not numeric: {parts[-1]}", file=sys.stderr)
        return 2

    metrics_script = REPO_ROOT / "experiments" / "metrics.py"
    r = subprocess.run(
        [sys.executable, str(metrics_script),
         "--repo", str(cell),
         "--task", task,
         "--condition", cond,
         "--run", str(run_n)],
        capture_output=True, text=True, encoding="utf-8", errors="replace")
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode

    (cell / "metrics.json").write_text(r.stdout, encoding="utf-8")
    print(str(cell / "metrics.json"))
    return 0


# ---------------------------------------------------------------------------
# validate (minimal schema check: required + type + enum + minimum)
# ---------------------------------------------------------------------------
TYPE_MAP = {
    "string": (str,),
    "integer": (int,),
    "boolean": (bool,),
    "number": (int, float),
}


def validate_record(rec, schema):
    errors = []
    required = schema.get("required", [])
    props = schema.get("properties", {})
    for key in required:
        if key not in rec or rec[key] is None:
            errors.append(f"missing required: {key}")
    for key, spec in props.items():
        if key not in rec:
            continue
        v = rec[key]
        if v is None:
            continue
        t = spec.get("type")
        if t:
            expected = TYPE_MAP.get(t)
            # bool is a subclass of int — disallow True where integer expected.
            if expected and (
                not isinstance(v, expected)
                or (t == "integer" and isinstance(v, bool))
            ):
                errors.append(f"{key}: expected {t}, got {type(v).__name__}")
                continue
        if "enum" in spec and v not in spec["enum"]:
            errors.append(f"{key}: value {v!r} not in enum {spec['enum']}")
        if "minimum" in spec and isinstance(v, (int, float)) and v < spec["minimum"]:
            errors.append(f"{key}: value {v} < minimum {spec['minimum']}")
    return errors


def cmd_validate(args):
    try:
        schema = json.loads(SCHEMA_PATH.read_text(encoding="utf-8"))
    except (OSError, ValueError) as e:
        print(f"error reading schema: {e}", file=sys.stderr)
        return 2
    try:
        rec = json.loads(Path(args.file).read_text(encoding="utf-8"))
    except (OSError, ValueError) as e:
        print(f"error reading {args.file}: {e}", file=sys.stderr)
        return 2
    errors = validate_record(rec, schema)
    if errors:
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        return 1
    return 0


# ---------------------------------------------------------------------------
# aggregate
# ---------------------------------------------------------------------------
AGG_COLS = [
    ("task", "task_id"),
    ("condition", "condition"),
    ("run", "run_id"),
    ("touched", "touched_files"),
    ("new", "new_files"),
    ("deps", "new_dependencies"),
    ("api", "public_api_additions"),
    ("out-corr", "out_of_corridor_files"),
    ("corr-chg", "corridor_changed"),
    ("success", "task_success"),
]


def cmd_aggregate(args):
    root = Path(args.root)
    rows = []
    for p in sorted(root.rglob("metrics.json")):
        try:
            rows.append(json.loads(p.read_text(encoding="utf-8")))
        except (OSError, ValueError):
            continue
    print("| " + " | ".join(h for h, _ in AGG_COLS) + " |")
    print("|" + "|".join("---" for _ in AGG_COLS) + "|")
    for m in rows:
        cells = [str(m.get(k, "")) for _, k in AGG_COLS]
        print("| " + " | ".join(cells) + " |")
    return 0


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
def main():
    p = argparse.ArgumentParser(prog="slime-bench")
    sub = p.add_subparsers(dest="cmd", required=True)

    pp = sub.add_parser("plan")
    pp.add_argument("task")
    pp.add_argument("--conditions", required=True,
                    help="comma-separated, e.g. baseline,prompt-only,hooked-slime")
    pp.add_argument("--runs", type=int, required=True)

    pn = sub.add_parser("new-cell")
    pn.add_argument("--task", required=True)
    pn.add_argument("--condition", required=True)
    pn.add_argument("--run", type=int, required=True)
    pn.add_argument("--fixture", required=True)
    pn.add_argument("--root", required=True)

    pm = sub.add_parser("measure")
    pm.add_argument("cell")

    pv = sub.add_parser("validate")
    pv.add_argument("file")

    pa = sub.add_parser("aggregate")
    pa.add_argument("root")

    args = p.parse_args()
    fn = {"plan": cmd_plan, "new-cell": cmd_new_cell,
          "measure": cmd_measure, "validate": cmd_validate,
          "aggregate": cmd_aggregate}[args.cmd]
    return fn(args) or 0


if __name__ == "__main__":
    sys.exit(main())

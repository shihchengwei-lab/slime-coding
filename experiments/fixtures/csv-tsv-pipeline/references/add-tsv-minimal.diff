--- /dev/null
+++ b/pipeline/readers/tsv_reader.py
@@ -0,0 +1,7 @@
+"""TSV reader: parse a tab-separated file into a list of dicts."""
+import csv
+
+
+def read(path):
+    with open(path, encoding="utf-8", newline="") as f:
+        return list(csv.DictReader(f, delimiter="\t"))

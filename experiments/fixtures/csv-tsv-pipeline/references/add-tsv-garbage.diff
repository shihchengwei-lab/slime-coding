new file mode 100644
--- /dev/null
+++ b/pipeline/readers/registry.py
@@ -0,0 +1,26 @@
+"""ReaderRegistry: format-name -> Reader strategy.
+
+We'll likely add more input formats (XML, YAML) later, so the registry lets
+future readers be plugged in without touching cli.py."""
+from .csv_reader import CsvReader
+from .tsv_reader import TsvReader
+
+
+class ReaderRegistry:
+    """Plugin-style registry for input-format Reader strategies."""
+
+    _readers = {}
+
+    @classmethod
+    def register(cls, name, reader_cls):
+        cls._readers[name] = reader_cls
+
+    @classmethod
+    def get(cls, name):
+        if name not in cls._readers:
+            raise ValueError(f"Unknown format: {name}")
+        return cls._readers[name]()
+
+
+ReaderRegistry.register("csv", CsvReader)
+ReaderRegistry.register("tsv", TsvReader)

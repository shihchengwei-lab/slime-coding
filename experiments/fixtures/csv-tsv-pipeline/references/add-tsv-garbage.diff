+"""Abstract base for input readers. Future readers (XML, YAML, Parquet, ...)
+plug in by subclassing Reader and registering with ReaderRegistry."""
+from abc import ABC, abstractmethod
+
+
+class Reader(ABC):
+    """Strategy interface for input format readers."""
+
+    @abstractmethod
+    def read(self, path):
+        """Read `path` and return a list of dicts."""

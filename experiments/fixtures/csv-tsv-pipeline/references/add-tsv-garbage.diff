@@ -0,0 +1,12 @@
+"""TSV reader implementation of the Reader strategy."""
+import csv
+
+from .base import Reader
+
+
+class TsvReader(Reader):
+    """Reader for TSV input. Registered as 'tsv' in ReaderRegistry."""
+
+    def read(self, path):
+        with open(path, encoding="utf-8", newline="") as f:
+            return list(csv.DictReader(f, delimiter="\t"))

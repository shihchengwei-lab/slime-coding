-"""Notes CLI: `add` and `list`. Insertion order is the baseline behaviour."""
+"""Notes CLI: `add`, `list`, and `export`. Insertion order is the baseline behaviour."""
 import argparse
+import json
 import sys
 
 from . import store
@@ -17,6 +18,26 @@ def cmd_list(args):
     return 0
 
 
+def export_json(notes):
+    """Render notes as a JSON array."""
+    return json.dumps(notes, indent=2)
+
+
+# Registry of export formats. Add new formats (csv, markdown, ...) here.
+EXPORTERS = {
+    "json": export_json,
+}
+
+
+def cmd_export(args):
+    notes = store.load(args.store)
+    render = EXPORTERS[args.format]
+    with open(args.outfile, "w", encoding="utf-8") as f:
+        f.write(render(notes))
+    print(f"exported {len(notes)} notes to {args.outfile}")
+    return 0
+
+
 def build_parser():
     p = argparse.ArgumentParser(prog="notes")
     p.add_argument("--store", default=None, help="path to the notes JSON file")
@@ -28,6 +49,16 @@ def build_parser():
 
     lst = sub.add_parser("list", help="list notes")
     lst.set_defaults(func=cmd_list)
+
+    exp = sub.add_parser("export", help="export notes to a file")
+    exp.add_argument("outfile")
+    exp.add_argument(
+        "--format",
+        choices=sorted(EXPORTERS),
+        default="json",
+        help="export format (default: json)",
+    )
+    exp.set_defaults(func=cmd_export)
     return p
 
 

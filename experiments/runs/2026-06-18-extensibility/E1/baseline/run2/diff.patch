diff --git a/cli_notes/exporters.py b/cli_notes/exporters.py
new file mode 100644
index 0000000..4e65ec0
--- /dev/null
+++ b/cli_notes/exporters.py
@@ -0,0 +1,25 @@
+"""Export notes to various file formats.
+
+Adding a format = add a function and register it in EXPORTERS. Each exporter
+takes (notes, outfile_path) and writes the file. JSON is the baseline; csv /
+markdown can slot in here later without touching the CLI wiring.
+"""
+import json
+
+
+def export_json(notes, path):
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(notes, f, indent=2)
+
+
+EXPORTERS = {
+    "json": export_json,
+}
+
+
+def export(notes, path, fmt="json"):
+    try:
+        exporter = EXPORTERS[fmt]
+    except KeyError:
+        raise ValueError(f"unknown export format: {fmt!r}")
+    exporter(notes, path)

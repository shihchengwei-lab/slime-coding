+def _export_json(notes, f):
+    json.dump(notes, f, indent=2)
+
+
+# Registry of export formats. Add new entries (csv, markdown, ...) here.
+EXPORTERS = {
+    "json": _export_json,
+}
+
+
+def cmd_export(args):
+    notes = store.load(args.store)
+    exporter = EXPORTERS[args.format]
+    with open(args.outfile, "w", encoding="utf-8") as f:
+        exporter(notes, f)
+    print(f"exported {len(notes)} notes to {args.outfile}")
+    return 0
+

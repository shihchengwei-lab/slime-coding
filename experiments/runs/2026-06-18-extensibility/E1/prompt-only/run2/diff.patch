+def cmd_export(args):
+    notes = store.load(args.store)
+    with open(args.outfile, "w", encoding="utf-8") as f:
+        json.dump(notes, f, indent=2)
+    print(f'exported {len(notes)} notes to {args.outfile}')
+    return 0
+
+
 def build_parser():
     p = argparse.ArgumentParser(prog="notes")
     p.add_argument("--store", default=None, help="path to the notes JSON file")
@@ -28,6 +37,10 @@ def build_parser():
 
     lst = sub.add_parser("list", help="list notes")
     lst.set_defaults(func=cmd_list)
+
+    exp = sub.add_parser("export", help="export notes as a JSON array")
+    exp.add_argument("outfile")
+    exp.set_defaults(func=cmd_export)
     return p
 
 

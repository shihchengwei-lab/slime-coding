--- a/cli_notes/store.py
+++ b/cli_notes/store.py
@@ -31,3 +31,10 @@ def add(text, path=None):
     notes.append(note)
     save(notes, path)
     return note
+
+
+def stats(path=None):
+    """Computed stats over the notes. Add future metrics (avg length,
+    oldest/newest) as more keys in this dict."""
+    notes = load(path)
+    return {"total": len(notes)}

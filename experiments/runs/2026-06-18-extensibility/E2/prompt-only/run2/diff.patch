+++ b/cli_notes/cli.py
@@ -17,6 +17,11 @@ def cmd_list(args):
     return 0
 
 
+def cmd_stats(args):
+    print(store.stats(args.store)["total"])
+    return 0
+
+
 def build_parser():
     p = argparse.ArgumentParser(prog="notes")
     p.add_argument("--store", default=None, help="path to the notes JSON file")
@@ -28,6 +33,9 @@ def build_parser():
 
     lst = sub.add_parser("list", help="list notes")
     lst.set_defaults(func=cmd_list)
+
+    st = sub.add_parser("stats", help="print stats about the notes")
+    st.set_defaults(func=cmd_stats)
     return p
 
 
diff --git a/cli_notes/store.py b/cli_notes/store.py

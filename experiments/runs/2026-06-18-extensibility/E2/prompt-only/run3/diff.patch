diff --git a/.slime/PRUNED.md b/.slime/PRUNED.md
new file mode 100644
index 0000000..cc3f776
--- /dev/null
+++ b/.slime/PRUNED.md
@@ -0,0 +1,9 @@
+# Pruned
+
+- Stats "engine"/registry mapping stat-name -> function (so future stats just
+  register). Rejected: only ONE stat (total) is required NOW; need >=2 real
+  variants before abstracting. A plain `cmd_stats` computing total inline is the
+  extension point for later stats.
+- Adding a `store.stats()` helper in store.py. Rejected: no second caller; the
+  count is `len(store.load(path))`, kept in the cli command. Avoids touching an
+  unrelated file.
diff --git a/.slime/corridor.md b/.slime/corridor.md
new file mode 100644
index 0000000..0748b0c
--- /dev/null
+++ b/.slime/corridor.md
@@ -0,0 +1,11 @@
+# Corridor: E2-B-3-stats
+
+Add a `stats` command that prints the total number of notes.
+Seam: cli.py's `cmd_* + sub.add_parser` pattern, reading via store.load().
+Computed inline so future stats (avg length, oldest/newest) extend the same
+function without a new abstraction.
+
+## Paths
+- cli_notes/cli.py
+- tests/test_cli.py
+- .slime/*.md
diff --git a/cli_notes/cli.py b/cli_notes/cli.py
index 02954eb..883f96f 100644
--- a/cli_notes/cli.py
+++ b/cli_notes/cli.py
@@ -17,6 +17,14 @@ def cmd_list(args):
     return 0
 
 
+def cmd_stats(args):
+    notes = store.load(args.store)
+    # Only "total" is needed now; future stats (avg length, oldest/newest)
+    # extend this function from the same loaded list.
+    print(len(notes))
+    return 0
+
+
 def build_parser():
     p = argparse.ArgumentParser(prog="notes")
     p.add_argument("--store", default=None, help="path to the notes JSON file")
@@ -28,6 +36,9 @@ def build_parser():
 
     lst = sub.add_parser("list", help="list notes")
     lst.set_defaults(func=cmd_list)
+
+    st = sub.add_parser("stats", help="print note statistics")
+    st.set_defaults(func=cmd_stats)
     return p
 
 

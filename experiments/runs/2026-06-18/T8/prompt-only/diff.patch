@@ -31,3 +31,12 @@ def add(text, path=None):
     notes.append(note)
     save(notes, path)
     return note
+
+
+def delete(note_id, path=None):
+    notes = load(path)
+    remaining = [n for n in notes if n["id"] != note_id]
+    if len(remaining) == len(notes):
+        return False
+    save(remaining, path)
+    return True

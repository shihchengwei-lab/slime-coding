 /// A tiny in-memory notes model. Fixture for the dependency gate — there is no
 /// Dart toolchain here, so this is read/edited, not executed.
+/// Returns a human-readable relative time for a past timestamp [t],
+/// e.g. "just now", "5 minutes ago", "2 hours ago", "3 days ago".
+String relativeTime(DateTime t) {
+  final elapsed = DateTime.now().difference(t);
+
+  if (elapsed.inSeconds < 60) return 'just now';
+
+  if (elapsed.inMinutes < 60) {
+    final m = elapsed.inMinutes;
+    return '$m ${m == 1 ? 'minute' : 'minutes'} ago';
+  }
+
+  if (elapsed.inHours < 24) {
+    final h = elapsed.inHours;
+    return '$h ${h == 1 ? 'hour' : 'hours'} ago';
+  }
+
+  final d = elapsed.inDays;
+  return '$d ${d == 1 ? 'day' : 'days'} ago';
+}

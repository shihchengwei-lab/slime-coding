+// Serialize notes to a string. Defaults to JSON; more formats (csv,
+// markdown) can be added as new entries in EXPORTERS later.
+const EXPORTERS = {
+  json: (notes) => JSON.stringify(notes),
+};
+
+function exportNotes(notes, format = "json") {
+  const exporter = EXPORTERS[format];
+  if (!exporter) {
+    throw new Error(`Unknown export format: ${format}`);
+  }
+  return exporter(notes);
+}
+
+module.exports = { addNote, listNotes, exportNotes };

@@ -15,3 +15,12 @@ test("add then list (insertion order)", () => {
 test("list empty", () => {
   assert.equal(listNotes([]), "");
 });
+
+test("exportNotes returns JSON string that round-trips to the notes array", () => {
+  let notes = [];
+  notes = addNote(notes, "hello");
+  notes = addNote(notes, "world");
+  const out = exportNotes(notes);
+  assert.equal(typeof out, "string");
+  assert.deepEqual(JSON.parse(out), notes);

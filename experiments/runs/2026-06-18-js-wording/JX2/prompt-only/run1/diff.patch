@@ -0,0 +1,13 @@
+# Corridor: JX2-B-1-export-notes
+
+Goal Frontier: `exportNotes(notes)` returns a string; `JSON.parse(exportNotes(notes))`
+deep-equals the notes array. "Easy to extend" = export rendering lives in one
+clearly-named pure function so a future format is added beside it. NOT a format
+registry/dispatcher (only one real format exists now).
+
+Start Frontier: src/notes.js, seam = pure functions over a notes array + the
+`module.exports` line.
+
+## Paths
+- src/notes.js
+- test/notes.test.js
diff --git a/src/notes.js b/src/notes.js
index 518970f..b525ca1 100644
--- a/src/notes.js
+++ b/src/notes.js
@@ -8,4 +8,10 @@ function listNotes(notes) {
   return notes.map((n) => `${n.id}\t${n.text}`).join("\n");
 }
 
-module.exports = { addNote, listNotes };
+// Render notes for export. Currently JSON only; a new format would be added as
+// a sibling renderer beside this one.
+function exportNotes(notes) {
+  return JSON.stringify(notes);
+}
+
+module.exports = { addNote, listNotes, exportNotes };

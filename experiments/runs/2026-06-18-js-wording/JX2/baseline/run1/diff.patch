diff --git a/src/notes.js b/src/notes.js
index 518970f..2ec888f 100644
--- a/src/notes.js
+++ b/src/notes.js
@@ -8,4 +8,25 @@ function listNotes(notes) {
   return notes.map((n) => `${n.id}\t${n.text}`).join("\n");
 }
 
-module.exports = { addNote, listNotes };
+// Output formatters keyed by name. Add new formats by registering a function
+// here (or via registerExportFormat); each takes the notes array and returns
+// a string.
+const exportFormats = {
+  json: (notes) => JSON.stringify(notes),
+};
+
+function registerExportFormat(name, formatter) {
+  exportFormats[name] = formatter;
+}
+
+// Serializes notes to a string. Defaults to JSON; pass a registered format
+// name to use a different output format.
+function exportNotes(notes, format = "json") {
+  const formatter = exportFormats[format];
+  if (!formatter) {
+    throw new Error(`Unknown export format: ${format}`);
+  }
+  return formatter(notes);
+}
+
+module.exports = { addNote, listNotes, exportNotes, registerExportFormat };

--- a/src/notes.js
+++ b/src/notes.js
@@ -8,4 +8,18 @@ function listNotes(notes) {
   return notes.map((n) => `${n.id}\t${n.text}`).join("\n");
 }
 
-module.exports = { addNote, listNotes };
+// Registry of output formats. Add a new format by registering a serializer
+// keyed by format name; exportNotes dispatches to it.
+const exporters = {
+  json: (notes) => JSON.stringify(notes),
+};
+
+function exportNotes(notes, format = "json") {
+  const serialize = exporters[format];
+  if (!serialize) {
+    throw new Error(`Unknown export format: ${format}`);
+  }
+  return serialize(notes);
+}
+
+module.exports = { addNote, listNotes, exportNotes, exporters };

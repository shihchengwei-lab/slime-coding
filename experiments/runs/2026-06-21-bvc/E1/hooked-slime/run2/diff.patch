+def cmd_export(args):
+    notes = store.load(args.store)
+    with open(args.file, "w", encoding="utf-8") as f:
+        json.dump(notes, f, indent=2)
+    print(f'exported {len(notes)} notes to {args.file}')
+    return 0
+
+
 def build_parser():
     p = argparse.ArgumentParser(prog="notes")
     p.add_argument("--store", default=None, help="path to the notes JSON file")
@@ -28,6 +37,10 @@ def build_parser():
 

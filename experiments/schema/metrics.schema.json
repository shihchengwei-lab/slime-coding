{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shihchengwei-lab/slime-coding/experiments/schema/metrics.schema.json",
  "title": "Slime Coding run metrics",
  "description": "One record per (task, condition, run). See docs/VALIDATION_PLAN.md §9-§10.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "condition",
    "run_id",
    "task_success",
    "tests_pass",
    "touched_files",
    "new_files",
    "new_dependencies",
    "public_api_additions",
    "out_of_corridor_files",
    "corridor_changed"
  ],
  "properties": {
    "task_id": { "type": "string", "description": "e.g. T1" },
    "condition": {
      "type": "string",
      "enum": ["baseline", "prompt-only", "hooked-slime", "hooked-no-l1"],
      "description": "Experiment condition A/B/C/D (plan §6)."
    },
    "run_id": { "type": "integer", "minimum": 1 },
    "task_success": { "type": "boolean" },
    "task_success_score": { "type": "integer", "enum": [0, 1, 2], "description": "Plan §10.1" },
    "tests_pass": { "type": "boolean" },
    "touched_files": { "type": "integer", "minimum": 0 },
    "new_files": { "type": "integer", "minimum": 0 },
    "new_dependencies": { "type": "integer", "minimum": 0 },
    "public_api_additions": { "type": "integer", "minimum": 0 },
    "out_of_corridor_files": { "type": "integer", "minimum": 0 },
    "corridor_changed": { "type": "boolean" },
    "pruned_path_revived": { "type": "boolean" },
    "unrelated_refactor_count": { "type": "integer", "minimum": 0 },
    "over_implementation_review": { "type": "integer", "enum": [0, 1, 2], "description": "Plan §10.3" },
    "reviewer_accept": { "type": "boolean" },
    "manual_reverts_required": { "type": "integer", "minimum": 0 },
    "blocks_count": { "type": "integer", "minimum": 0, "description": "L2 hard-block count (plan §10.4)" },
    "false_block_count": { "type": "integer", "minimum": 0 },
    "manual_steps": { "type": "integer", "minimum": 0 },
    "turn_count": { "type": "integer", "minimum": 0 },
    "abandon_reason": { "type": "string" },
    "notes": { "type": "string" }
  }
}
